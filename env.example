# 服务器配置
PORT=3000

# GitHub API Token (可选，用于提高 GitHub Search API 的速率限制)
GITHUB_TOKEN=

# Gemini API 密钥 (必填，用于 AI 商业化变现评估)
GEMINI_API_KEY=

# 数据库路径 (可选，默认在 data/github_trending.db)
DB_PATH=

# 邮件服务配置 (可选，用于定时推送周报)
EMAIL_SERVICE=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=

# 飞书多维表推送配置 (可选，基于 lark-cli)
FEISHU_LEDGER_BASE_TOKEN=your_feishu_bitable_base_token
FEISHU_LEDGER_TABLE_ID=your_feishu_bitable_table_id

# 推送时间间隔 (小时，默认为 24 小时)
PUSH_INTERVAL=24

# 自定义监控的主题/应用场景池 (英文逗号分隔)
CATEGORIES=副业,变现,自媒体,小红书,抖音,微信,效率,办公自动化,去水印,AI工具,人工智能,娱乐,影视,游戏脚本
